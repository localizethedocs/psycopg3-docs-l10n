msgstr ""

#: ../../../api/copy.rst:96
msgid ""
"This writer should be used without executing a :sql:`COPY` operation on the "
"database. For example, if `records` is a list of tuples containing data to "
"save in COPY format to a file (e.g. for later import), it can be used as:"
msgstr ""

#: ../../../api/copy.rst:101
msgid ""
"with open(\"target-file.pgcopy\", \"wb\") as f:\n"
"    with Copy(cur, writer=FileWriter(f)) as copy:\n"
"        for record in records\n"
"            copy.write_row(record)"
msgstr ""

