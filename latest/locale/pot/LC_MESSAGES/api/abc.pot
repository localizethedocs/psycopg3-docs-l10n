msgstr ""

#: ../../../api/abc.rst:23 ../../../api/abc.rst:74
msgid ""
"The context where the transformation is performed. If not specified the "
"conversion might be inaccurate, for instance it will not be possible to know "
"the connection encoding or the server date format."
msgstr ""

