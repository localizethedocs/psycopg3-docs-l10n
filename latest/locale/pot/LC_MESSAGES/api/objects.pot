#: ../../../api/objects.rst:127
msgid ""
"Every feature check is implemented by an `!has_SOMETHING()` method. All the "
"methods return a boolean value stating if the capability is supported, which "
"can be used by a program to degrade gracefully::"
msgstr ""

#: ../../../api/objects.rst:131
msgid ""
"if psycopg.capabilities.has_pipeline()\n"
"    with conn.pipeline():\n"
"        operations(conn)\n"
"else:\n"
"    logger.warning(\"slower\")\n"
"    operations(conn)"
