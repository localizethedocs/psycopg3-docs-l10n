#: ../../../../../../.conda/lib/python3.14/site-packages/psycopg/sql.py:docstring
#: of psycopg.sql.as_bytes:4 psycopg.sql.as_string:4
msgid "the context in which to convert the object"
msgstr ""

#: ../../../../../../.conda/lib/python3.14/site-packages/psycopg/sql.py:docstring
#: of psycopg.sql.as_string:7
msgid "Adaptation happens according to the type of `!obj`:"
msgstr ""

#: ../../../../../../.conda/lib/python3.14/site-packages/psycopg/sql.py:docstring
#: of psycopg.sql.as_string:9
msgid ""
"`Composable` objects are converted according to their `~Composable."
"as_string()` method;"
msgstr ""

#: ../../../../../../.conda/lib/python3.14/site-packages/psycopg/sql.py:docstring
#: of psycopg.sql.as_string:11
msgid ""
"`~string.templatelib.Template` strings are converted according to the rules "
"documented in :ref:`template-strings`;"
msgstr ""

#: ../../../../../../.conda/lib/python3.14/site-packages/psycopg/sql.py:docstring
#: of psycopg.sql.as_string:13
msgid ""
"every other object is converted as it was :ref:`a parameter passed to a "
"query <types-adaptation>`."
msgstr ""

#: ../../../../../../.conda/lib/python3.14/site-packages/psycopg/sql.py:docstring
