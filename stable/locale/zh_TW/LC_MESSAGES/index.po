msgid "Psycopg 3 -- PostgreSQL database adapter for Python"
msgstr "Psycopg 3 -- Python 的 PostgreSQL 資料庫適配器"

#: ../../../index.rst:5
msgid ""
"Psycopg 3 is a newly designed PostgreSQL_ database adapter for the Python_ "
"programming language."
msgstr "Psycopg 3 是為 Python_ 程式語言新設計的 PostgreSQL_ 資料庫適配器。"

#: ../../../index.rst:8
msgid ""
