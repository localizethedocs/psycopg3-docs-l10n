msgstr ""

#: ../../../../../../.conda/lib/python3.14/site-packages/psycopg/types/composite.py:docstring
#: of psycopg.types.composite.register_composite:22
#: ../../../../../../.conda/lib/python3.14/site-packages/psycopg/types/hstore.py:docstring
#: psycopg.types.hstore.register_hstore:9
